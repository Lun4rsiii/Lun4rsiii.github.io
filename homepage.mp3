  <div id="_ctl0_Content_videoPlayer1" class="videoPlayer">
    
    <!-- Youtube API player 2016 -->
    <iframe id="player" frameborder="0" allowfullscreen="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" title="City of Winds and Idylls - Disc 1: City of Winds and Idylls｜Genshin Impact" width="640" height="360" src="./homepage_files/AALrH26HAmw.html"></iframe>
    
    <script language="JavaScript" type="text/javascript">

        // video params
        videoID = "AALrH26HAmw";
        startSec = 0;
        endSec = 0;
        repeat_mini = 0;
        repeat_url = '/VideoRepeated';

        // load player API javascript
        var tag = document.createElement('script');
        tag.src = "//www.youtube.com/iframe_api";
        var firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

        // init function
        function onYouTubeIframeAPIReady() 
        {
            // alert("onYouTubeIframeAPIReady");

            // ytplayer from player_js
            var p = new YT.Player('player',
            {
              width: '640',
              height: '360',
              videoId: videoID,
              playerVars: { 'autoplay': 1, 'loop': 1, 'controls': 2, 'showinfo': 0, 'start': startSec, 'iv_load_policy': 3 },
              events: {
                  onReady: onPlayerReady,
                  onStateChange: onPlayerStateChange,
                  onError: onPlayerError
              }
            });

            // set repeat status
            SetRepeatStartEndStatus();

            // hide time box in 10 sec
            delay_hide_timebox = setTimeout('delayHideTimeBox()', 10000);
            
   


let spaceHeld = false;
let spaceTimer = null;
let spaceIsHold = false;

document.addEventListener("keydown", e => {
  if (!p) return;

  if (e.code === "Space") {
    //e.preventDefault();

    if (!spaceHeld) {
      spaceHeld = true;
      spaceIsHold = false;
      spaceTimer = setTimeout(() => {
        spaceIsHold = true;
        p.setPlaybackRate(2);
      }, 250);

      return;
    }
  }
   var STEP = 10;   var  v;   var speed;
  const isArrow = e.key.startsWith("Arrow");
  if (!isArrow) return;
     STEP = 10;
  const VOL_STEP = 10;
         v = p.getVolume();
          speed = p.getPlaybackRate();
  if (p.getPlayerState() !== YT.PlayerState.PLAYING) 
  {   STEP = 1/22;     }       

  if (e.key === "ArrowRight") {
  
/*  if (spaceIsHold) {
   speed = Math.min(speed + 1, 8);
  p.setPlaybackRate(speed);
if (speed < -1 || speed > 2.8 )  {
if ( v != 0) { p.setVolume(0) ; var vprev = v;  }  
} else { if (v == 0 && vprev) {p.setVolume(vprev) }} 

}  else  {                                         */
    p.seekTo(p.getCurrentTime() + STEP, true);  // }

  }

  if (e.key === "ArrowLeft") {
    p.seekTo(p.getCurrentTime() - STEP, true);
  }

  if (e.key === "ArrowUp") {
    v = p.getVolume();
    p.setVolume(Math.min(100, v + VOL_STEP));
  }

  if (e.key === "ArrowDown") {
    v = p.getVolume();
    p.setVolume(Math.max(0, v - VOL_STEP));
  }
});

document.addEventListener("keyup", e => {
  if (!p) return;

  if (e.code === "Space") {
    clearTimeout(spaceTimer);

    if (!spaceIsHold) {
      const state = p.getPlayerState();
      if (state === YT.PlayerState.PLAYING) p.pauseVideo();
      else p.playVideo();
    }

    spaceHeld = false;
    spaceIsHold = false;
    p.setPlaybackRate(1);
  }
});
         
            
            
        }

    </script>

