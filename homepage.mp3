         <style>
         
         
#beforeTag{

  position:absolute;
  top:40px;left:280px;
  background:rgba(225,222,222,0.3);
  border-radius:5px;
  font-size:14px; line-height:15px; font-family: Arial Narrow
  cursor:pointer;
  border:1px solid #dadce0;
  z-index:2147483647 !important;
  user-select:none; color:#555; font-weight:400;
}
#beforeTag.on{
  background:rgba(255,252,222,0.5);
  border-color:#fe0;  color:#555
}
</style>


<script>
function triggerEnter(input){
  input.focus();
  input.value = input.value; // sync 
  input.dispatchEvent(new KeyboardEvent("keydown", {
    key: "Enter",
    code: "Enter",
    keyCode: 13,
    which: 13,
    bubbles: true
  }));
}       
                             
function init(){
  const box = document.querySelector("#___gcse_0");
  if (!box || document.getElementById("beforeTag")) return; 
  box.style.position = "relative";

  const tag = document.createElement("div");
  tag.id = "beforeTag";
  tag.innerHTML = "before:2024";
  tag.title = "(Can avoid AI Videos)   (some of us search old music)";
  box.appendChild(tag);

  const input = box.querySelector("input");
  if (!input) return;
let timer = null;

input.addEventListener("keyup", (e) => {
  if (e.key === "Enter") return;

  clearTimeout(timer);

  timer = setTimeout(() => {
    run();
    timer = null;
  }, 1800);
});

function reset() {
  clearTimeout(timer);
  timer = setTimeout(() => {
    timer = null;
  }, 1800);
}

input.addEventListener("keydown", reset);

const inContainer = el => el?.closest?.(".gsc-completion-container");

document.addEventListener("mouseover", e => {
 if (inContainer(e.target)) reset();
}, true);
document.addEventListener("touchstart", e => {
  if (inContainer(e.target)) reset();
}, { passive: true });
/* document.addEventListener("focusin", e => {
  if (inContainer(e.target)) reset();
});
document.addEventListener("selectionchange", () => {
  const s = window.getSelection();
  if (s && !s.isCollapsed && inContainer(s.anchorNode?.parentElement)) active();
});
  */

  const sync = () => {
    tag.classList.toggle("on", input.value.includes("before:2024"));
  };

  const run = () => {
    sync();
    triggerEnter(input);
  };

  tag.onclick = () => {
    let q = input.value.trim();

    q = q.includes("before:2024")
      ? q.replace(/\s+before:2024/, "")
      : q + " before:2024";

    input.value = q;

    run();
  };


  sync();
}

const wait = setInterval(() => {
  if (window.google?.search?.cse) {
    clearInterval(wait);
    init();
  }
}, 150);
</script>




