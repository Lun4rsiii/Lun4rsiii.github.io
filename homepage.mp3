<script>
(function(){
const BAR_COUNT = 50*(window.width || screen.width)/1800;
const MIN_SCALE = 0.2;
function getPlayer(){
  return document.querySelector("video, #player");
}
function createFX(){
  const fx = document.createElement("div");
  fx.id = "ambientFX";
  document.body.appendChild(fx);
  for(let i=0;i<BAR_COUNT;i++){
    const b = document.createElement("div");
    b.className = "afx-bar";
    fx.appendChild(b);
  }
  return fx;
}
function positionFX(fx, player){
  const r = player.getBoundingClientRect();
  fx.style.left = r.left + "px";
  fx.style.width = r.width + "px";
  fx.style.top = "0px";
  fx.style.height = r.top + "px";
}
/* =========================
   ANIMATION ========================= */
function fallback(bars, fx){
  let t = 0;
  function loop(){
    t += 0.05;
    const faint = fx.classList.contains("faint");
    const frozen = fx.classList.contains("frozen");     
    bars.forEach((b,i)=>{
      let v = (Math.sin(t + i*0.3) + 1)/2;
      if(faint) v *= 0.9;
      if(frozen) v = 0;

      b.style.transform =
        `scaleY(${Math.max(MIN_SCALE, v)})`;
    });

    requestAnimationFrame(loop);
  }

  loop();
}

/* =========================
   INIT
========================= */
function init(){
  const player = getPlayer();
  if(!player) return setTimeout(init,800);

  const fx = createFX();
  const bars = [...fx.children];

  function update(){
    positionFX(fx, player);
  }

  update();
  addEventListener("resize", update);
  addEventListener("scroll", update);

  fallback(bars, fx);

  /* =========================
     3 STATE CONTROLLER
  ========================= */
  let t1, t2;

  function show(){

    // ACTIVE (0–1.8s)
    document.body.classList.remove("dim");
    fx.classList.add("active");
    fx.classList.remove("faint","frozen");
    // gecko.style.opacity="0.82";  

    clearTimeout(t1);
    clearTimeout(t2); 

    // FAINT (1.8s)
    t1 = setTimeout(()=>{
      fx.classList.remove("active");
      fx.classList.add("faint");
    },2200);

    // DEEP IDLE (5s)
    t2 = setTimeout(()=>{
      document.body.classList.add("dim");
      fx.classList.remove("active","faint");
      fx.classList.add("frozen");
      gecko.style.opacity="0";
    },3800);
  }

  addEventListener("mousemove", show);
  addEventListener("touchstart", show);
  addEventListener("scroll", show);
  addEventListener("keyup", show);
  show();
}

init();

})();





</script>






    
