      .gsc-results-wrapper-overlay,
      .gsc-results-wrapper-visible , .gsc-webResult,  .gsc-result {    max-width: min(500px, ${window.innerWidth - 12}px) !important; 
        left: ${rect.left}px !important;     
        top: min(calc(56.25vw + 95px), calc(23px + ${rect.bottom}px)) !important;
      //  transform: scale(${scale}); 
       transform-origin: top left;  
        object-fit:contain !important;      } 
        .gs-image {padding-left: -15px;}
 
            .gsc-webResult *,  .gsc-result  * {padding:-5px !important}    

      
    `;
  }

  document.head.appendChild(style);
}

